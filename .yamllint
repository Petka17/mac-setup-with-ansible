---
extends: default

# The comments/braces/octal-values settings mirror what ansible-lint's
# built-in yaml rules require — it refuses a custom .yamllint without them.
rules:
  # Task files carry long explanatory comments; 80 is too tight.
  line-length:
    max: 120
  # Allow `on:` as a key (GitHub workflow syntax).
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
